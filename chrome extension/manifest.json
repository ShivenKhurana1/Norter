{
  "manifest_version": 3,
  "name": "Norter",
  "version": "2.0",
  "description": "Research assistant with notes, citations, and productivity tools",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.crossref.org/*",
    "https://export.arxiv.org/*",
    "https://api.semanticscholar.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "open-citation-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Open citation picker"
    }
  }
}