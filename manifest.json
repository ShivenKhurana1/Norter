{
  "manifest_version": 3,
  "name": "Norter",
  "version": "2.0",
  "description": "Research assistant with notes, citations, and productivity tools",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.crossref.org/*",
    "https://export.arxiv.org/*",
    "https://api.semanticscholar.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tesseract.min.js", "worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}